@using System.Globalization
@inject IJSRuntime Js
@inject StackStore Store
@inject UsageCounters Counters
@inject NavigationManager Nav

@{
    var scored = Groups.SelectMany(g => g.Members).Where(m => m.IsScored).ToList();
    var envSla = Availability.Serial(scored.Select(m => m.Variant!.Sla));
    var envSlaText = (envSla * 100).ToString("F3", CultureInfo.InvariantCulture);
    var envGauge = (Math.Clamp((Availability.Nines(envSla) - 1) / 4.0, 0, 1) * 100)
        .ToString("F1", CultureInfo.InvariantCulture);
    var topWeakest = scored.OrderByDescending(m => m.DowntimeHoursPerYear).Take(5).ToList();
    var crit = Criticality.Get(_criticalityId);
    var plan = TargetPlanner.Plan(scored, crit.TargetSla);
    var unknown = Groups.SelectMany(g => g.Unknown).ToList();
    var notApplicable = Groups.SelectMany(g => g.NotApplicable).ToList();
}

<!-- ============ ONE number. That's the product. ============ -->
<div class="rp-header-card">
    <div class="gauge-glow"></div>
    <div class="rp-header-grid">
        <div>
            <span class="gauge-label">COMPOSITE SLA · YOUR ENVIRONMENT</span>
            <div class="rp-figure">@envSlaText<span class="accent">%</span></div>
            <div class="gauge-subfigure">
                ≈ @Availability.DowntimeHoursPerYear(envSla).ToString("F1", CultureInfo.InvariantCulture) h/yr downtime budget
                · @Availability.Nines(envSla).ToString("F1", CultureInfo.InvariantCulture) nines
                · @scored.Count resources in @Groups.Count group(s), worst-case serial
            </div>
            <div class="gauge rp-gauge" data-gauge data-value="@envGauge">
                <div class="gauge-track">
                    <div class="gauge-fill"></div>
                    <div class="gauge-knob"></div>
                </div>
                <div class="gauge-scale">
                    <span>9</span><span>99</span><span>99.9</span><span>99.99</span><span>99.999</span>
                </div>
            </div>
        </div>
        <div class="rp-share">
            <span class="rp-share-label">README BADGE</span>
            <span class="uptime-badge"><span class="ub-left">OnlyNines</span><span class="ub-right">@((envSla * 100).ToString("F2", CultureInfo.InvariantCulture))%</span></span>
            @if (SavedSlug is not null)
            {
                <button class="copy-quiet rp-share-btn" @onclick="() => CopyText(PermalinkUrl)">⧉ @_copyPermalinkLabel</button>
                <button class="copy-quiet rp-share-btn" @onclick="() => CopyText(BadgeMarkdown)">⧉ @_copyBadgeLabel</button>
            }
            else if (Store.Enabled && RawInput is not null)
            {
                <button class="btn-primary rp-save-btn" @onclick="SaveStack" disabled="@_saving">@(_saving ? "Saving…" : "Save → permalink + live badge")</button>
                <span class="rp-share-hint">saves the inventory you pasted; the report re-scores on every visit</span>
            }
            else if (Store.Enabled)
            {
                <span class="rp-share-hint"><a class="accent" href="/assess">run your own assessment</a> to save &amp; get a live badge</span>
            }
            else
            {
                <span class="rp-share-hint">deploy with a database to enable permalinks &amp; live badges</span>
            }
        </div>
    </div>
</div>

<!-- ============ WAF verdict: does raising the nines even make sense? ============ -->
<div class="rp-card">
    <div class="rp-card-heading">
        <h2>How critical is this workload?</h2>
        <span class="mono-muted"><a class="accent" href="https://learn.microsoft.com/azure/well-architected/reliability/metrics" target="_blank" rel="noopener">WAF: define reliability targets ↗</a></span>
    </div>
    <div class="seg-tabs">
        @foreach (var c in Criticality.Classes)
        {
            <button class="seg-tab @(c.Id == crit.Id ? "seg-tab-active" : "")"
                    title="@c.Blurb"
                    @onclick="() => _criticalityId = c.Id">@c.Label · @((c.TargetSla * 100).ToString("G", CultureInfo.InvariantCulture))%</button>
        }
    </div>

    <div class="verdict verdict-@plan.Verdict.ToString().ToLowerInvariant()">
        @switch (plan.Verdict)
        {
            case TargetVerdict.OnTarget:
                <strong>ON TARGET.</strong>
                <span>@((plan.CurrentSla * 100).ToString("F3", CultureInfo.InvariantCulture))% meets the @crit.Label target. Don't touch it — every further nine is a vanity metric you'll pay for monthly.</span>
                break;
            case TargetVerdict.Under:
                <strong>UNDER TARGET.</strong>
                <span>You're @(((crit.TargetSla - plan.CurrentSla) * 100).ToString("F3", CultureInfo.InvariantCulture)) points short. The @plan.NeededUpgrades.Count upgrade(s) below get you to @((plan.SlaAfterNeeded * 100).ToString("F3", CultureInfo.InvariantCulture))% — and that's where you should stop.</span>
                break;
            case TargetVerdict.Over:
                <strong>OVER-ENGINEERED.</strong>
                <span>You're above the @crit.Label target with room to spare. @plan.DowngradeCandidates.Count resource(s) below can step down a tier — same verdict, smaller bill.</span>
                break;
            case TargetVerdict.Unreachable:
                <strong>TARGET UNREACHABLE WITH TIER UPGRADES.</strong>
                <span>Even maxing every ladder gets you to @((plan.SlaAfterNeeded * 100).ToString("F3", CultureInfo.InvariantCulture))%. This target needs architecture, not tiers: redundant sets across zones, multi-region. <a class="accent" href="https://learn.microsoft.com/azure/well-architected/reliability/redundancy" target="_blank" rel="noopener">WAF: redundancy ↗</a></span>
                break;
        }
    </div>

    @if (plan.Verdict is TargetVerdict.Under or TargetVerdict.Unreachable && plan.NeededUpgrades.Count > 0)
    {
        <div class="verdict-list">
            <div class="verdict-list-title">Worth doing (in this order):</div>
            @foreach (var m in plan.NeededUpgrades)
            {
                <div class="sla-variant-row">
                    <span class="wl-chip">@(m.Resource.Name ?? m.Resource.Id)</span>
                    <span class="mono-muted">@m.Variant!.Id →</span>
                    <span class="sla-value">@m.NextRung!.Id</span>
                    <span class="rp-delta">−@(((m.NextRung!.Sla - m.Variant!.Sla) * Availability.HoursPerYear).ToString("F1", CultureInfo.InvariantCulture)) h/yr</span>
                </div>
            }
            @if (plan.BeyondTarget.Count > 0)
            {
                <div class="verdict-beyond">@plan.BeyondTarget.Count more upgrade(s) possible — your target doesn't justify them.</div>
            }
        </div>
    }

    @if (plan.Verdict == TargetVerdict.Over)
    {
        <div class="verdict-list">
            <div class="verdict-list-title">Downgrade candidates (each independently keeps the target):</div>
            @foreach (var m in plan.DowngradeCandidates)
            {
                <div class="sla-variant-row">
                    <span class="wl-chip">@(m.Resource.Name ?? m.Resource.Id)</span>
                    <span class="mono-muted">@m.Variant!.Id →</span>
                    <span class="sla-value">@m.PrevRung!.Id</span>
                    <span class="mono-muted">@(m.PrevRung!.UpgradeNote is null ? "" : m.PrevRung!.UpgradeNote)</span>
                </div>
            }
        </div>
    }
</div>

<!-- ============ Top weakest links, whole environment ============ -->
@if (topWeakest.Count > 0)
{
    <div class="rp-card">
        <div class="rp-card-heading">
            <h2>Weakest links</h2>
            <span class="mono-muted">top @topWeakest.Count across the environment · h/yr</span>
        </div>
        <div class="rp-table">
            <div class="rp-table-head">
                <span>#</span><span>Resource · current tier</span><span class="rp-right">Costs</span><span>Next rung</span>
            </div>
            @for (var i = 0; i < topWeakest.Count; i++)
            {
                var w = topWeakest[i];
                <div class="rp-row">
                    <span class="rp-rank">@(i + 1)</span>
                    <div class="wl-name">@(w.Resource.Name ?? w.Resource.Id)<span class="wl-tier">@(w.Service?.Service) · @(w.Variant!.Id) · @(w.Resource.ResourceGroup)</span></div>
                    <span class="wl-cost rp-right">@w.DowntimeHoursPerYear.ToString("F1", CultureInfo.InvariantCulture)<span class="rp-unit"> h/yr</span></span>
                    <span>
                        @if (w.NextRung is { } next)
                        {
                            <span class="wl-chip">@next.Id</span>
                            <span class="rp-delta">−@(((next.Sla - w.Variant!.Sla) * Availability.HoursPerYear).ToString("F1", CultureInfo.InvariantCulture)) h/yr</span>
                        }
                        else
                        {
                            <span class="mono-muted">—</span>
                        }
                    </span>
                </div>
            }
        </div>
    </div>
}

<!-- ============ Per-group breakdown, collapsed by default ============ -->
@if (Groups.Count > 1)
{
    <div class="rp-card">
        <div class="rp-card-heading">
            <h2>By resource group</h2>
            <span class="mono-muted">click to expand</span>
        </div>
        @foreach (var group in Groups)
        {
            var weakest = group.WeakestLinks.ToList();
            <details class="rp-group">
                <summary>
                    <span class="rp-group-name">@group.Group</span>
                    <span class="rp-group-figures">
                        <span class="sla-value">@((group.CompositeSla * 100).ToString("F3", CultureInfo.InvariantCulture))%</span>
                        <span class="mono-muted">@group.DowntimeHoursPerYear.ToString("F1", CultureInfo.InvariantCulture) h/yr</span>
                    </span>
                </summary>
                @if (weakest.Count > 0)
                {
                    <div class="rp-group-body">
                        @foreach (var w in weakest)
                        {
                            <div class="rp-row">
                                <span class="rp-rank">·</span>
                                <div class="wl-name">@(w.Resource.Name ?? w.Resource.Id)<span class="wl-tier">@(w.Service?.Service) · @(w.Variant!.Id)</span></div>
                                <span class="wl-cost rp-right">@w.DowntimeHoursPerYear.ToString("F1", CultureInfo.InvariantCulture)<span class="rp-unit"> h/yr</span></span>
                                <span>
                                    @if (w.NextRung is { } next)
                                    {
                                        <span class="wl-chip">@next.Id</span>
                                        <span class="rp-delta">+@(((next.Sla - w.Variant!.Sla) * 100).ToString("F2", CultureInfo.InvariantCulture))%</span>
                                    }
                                    else
                                    {
                                        <span class="mono-muted">—</span>
                                    }
                                </span>
                            </div>
                        }
                    </div>
                }
            </details>
        }
    </div>
}

<!-- ============ Honesty section: unknown + not-applicable, once ============ -->
@if (unknown.Count > 0)
{
    <div class="rp-unknown">
        <div>
            <div class="rp-unknown-title">● Unknown bucket</div>
            <p>
                @unknown.Count resource(s) have no published Microsoft SLA in our dataset, so we
                <strong>excluded</strong> them from the composite rather than guess.
                They're not hidden — they're just not counted.
            </p>
            <div class="rp-unknown-chips">
                @foreach (var u in unknown)
                {
                    <span class="ub-tag">@(u.Resource.Name ?? u.Resource.Type)</span>
                }
            </div>
        </div>
    </div>
}

@if (notApplicable.Count > 0)
{
    <div class="rp-na">
        <span class="mono-muted">Not counted (by design):</span>
        @foreach (var na in notApplicable)
        {
            <span class="ub-tag" title="@na.Service!.IgnoreReason">@(na.Resource.Name ?? na.Resource.Type)</span>
        }
    </div>
}

<div class="rp-methodology-link">
    <a class="teaser-link" href="/methodology">Methodology &amp; SLA sources →</a>
</div>

<div class="rp-footnote"><span class="accent">ⓘ</span> Designed availability, not a guarantee.</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<GroupScore> Groups { get; set; } = Array.Empty<GroupScore>();

    /// <summary>Raw pasted inventory — enables the save button when the store is configured.</summary>
    [Parameter] public string? RawInput { get; set; }

    /// <summary>Set when rendering an already-saved stack (shows share actions instead of save).</summary>
    [Parameter] public string? SavedSlug { get; set; }

    /// <summary>Criticality preselected from a saved stack.</summary>
    [Parameter] public string? InitialCriticality { get; set; }

    private bool _saving;
    private string? _criticalityId;
    private string _copyPermalinkLabel = "Copy permalink";
    private string _copyBadgeLabel = "Copy badge markdown";

    protected override void OnParametersSet() =>
        _criticalityId ??= InitialCriticality;

    private string PermalinkUrl => $"{Nav.BaseUri.TrimEnd('/')}/stack/{SavedSlug}";
    private string BadgeMarkdown =>
        $"[![OnlyNines]({Nav.BaseUri.TrimEnd('/')}/badge/{SavedSlug}.svg)]({PermalinkUrl})";

    private async Task SaveStack()
    {
        if (RawInput is null) return;
        _saving = true;
        var slug = await Store.SaveAsync(new StackPayload(RawInput, _criticalityId).Wrap());
        Telemetry.StacksSaved.Add(1);
        _ = Counters.IncrementAsync("stack_saved");
        Nav.NavigateTo($"/stack/{slug}");
    }

    private async Task CopyText(string text)
    {
        await Js.InvokeVoidAsync("onlyninesCopyText", text);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await Js.InvokeVoidAsync("onlyninesRefreshGauges");
    }
}
