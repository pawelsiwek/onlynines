@page "/sla/{Slug}"
@using System.Globalization
@inject DatasetProvider Dataset

@if (_service is null)
{
    <PageTitle>Unknown service — OnlyNines</PageTitle>
    <SiteNav />
    <div class="page-shell">
        <span class="mono-eyebrow">// 404</span>
        <h1 class="page-title">We don't have that one.</h1>
        <p class="page-sub"><a class="accent" href="/sla">Browse the full dataset →</a></p>
    </div>
}
else
{
    <PageTitle>@_service.Service SLA — downtime per year, zone redundancy — OnlyNines</PageTitle>
    <HeadContent>
        <meta name="description" content="@_service.Service SLA explained: availability per tier, allowed downtime per year and month, and what configuration buys the next nine." />
        <link rel="canonical" href="https://onlynines.app/sla/@Slug" />
    </HeadContent>
    <SiteNav />
    <div class="page-shell">
        <span class="mono-eyebrow">// sla</span>
        <h1 class="page-title">@_service.Service</h1>
        <p class="page-sub">
            Resource type: <code>@_service.ResourceType</code> · verified @_service.LastVerified ·
            <a class="accent" href="@_service.DocsUrl" target="_blank" rel="noopener">official SLA document ↗</a>
        </p>

        <div class="rp-card">
            <div class="rp-card-heading">
                <h2>Tiers</h2>
                <span class="mono-muted">weakest → strongest</span>
            </div>
            @foreach (var v in _service.Variants)
            {
                var downtime = Availability.DowntimeHoursPerYear(v.Sla);
                <div class="sla-variant-row">
                    <span class="wl-chip">@v.Id</span>
                    <span class="sla-value">@((v.Sla * 100).ToString("F3", CultureInfo.InvariantCulture))%</span>
                    <span class="mono-muted">@downtime.ToString("F1", CultureInfo.InvariantCulture) h/yr · @((downtime / 12).ToString("F1", CultureInfo.InvariantCulture)) h/mo</span>
                    @if (v.UpgradeNote is not null)
                    {
                        <span class="sla-note">@v.UpgradeNote</span>
                    }
                </div>
            }
        </div>

        <p class="page-sub">
            This service is one link in your chain — composite availability is the product of every
            hard dependency. <a class="accent" href="/assess">Compute yours from one Resource Graph query →</a>
        </p>

        <div class="rp-footnote"><span class="accent">ⓘ</span> Draft values pending verification. Designed availability, not a guarantee.</div>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private SlaService? _service;

    protected override void OnParametersSet() =>
        _service = Dataset.Services.FirstOrDefault(s => !s.Ignore && DatasetProvider.SlugFor(s) == Slug);
}
